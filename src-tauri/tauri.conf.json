{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FView",
  "version": "0.1.0",
  "identifier": "com.fview.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FView",
        "width": 1100,
        "height": 760,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "Open a file in FView",
      "longDescription": "Open a file in FView. Supports Markdown, PDF, TXT, code, HTML, and images.",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "description": "Path of the file to open"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Minimal file preview & editor",
    "longDescription": "A Typora-like minimal file preview & editor for Markdown, PDF, TXT, code, HTML, and images."
  }
}
